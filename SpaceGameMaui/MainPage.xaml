<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpaceGameMaui.MainPage">

    <VerticalStackLayout>

        <GraphicsView x:Name="GameView" HeightRequest="500"/>

        <HorizontalStackLayout HorizontalOptions="Center">
            <Button Text="Left" Pressed="OnLeftPressed" Released="OnLeftReleased"/>
            <Button Text="Shoot" Clicked="OnShoot"/>
            <Button Text="Right" Pressed="OnRightPressed" Released="OnRightReleased"/>
        </HorizontalStackLayout>

    </VerticalStackLayout>

</ContentPage>
